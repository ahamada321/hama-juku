---
const { 
  title = 'よくある質問と答え', 
  description = '※登録解除はいつでも可能です',
} = Astro.props;
---

<section id="mailing-list-form" class="relative bg-white pb-8 overflow-hidden">
  <!-- Mailing List Form -->
  <div class="ml-embedded" data-form="JdgU6z"></div>
  <p class="text-md text-gray-600 max-w-2xl mx-auto text-center">{description}</p>

  <!-- MailerLite Universal Script -->
  <script is:inline>
    (function(w,d,e,u,f,l,n){
      w[f]=w[f]||function(){(w[f].q=w[f].q||[]).push(arguments);};
      l=d.createElement(e);
      l.async=1;
      l.src=u;
      n=d.getElementsByTagName(e)[0];
      n.parentNode.insertBefore(l,n);
    })(window,document,'script','https://assets.mailerlite.com/js/universal.js','ml');
    ml('account', '258165');
  </script>
</section>