---
import FaqItem from './FaqItem.astro';

interface Faq {
  question: string;
  answer: string;
}

interface Props {
  title?: string;
  description?: string;
  faqs?: Faq[];
}

const { 
  title = 'よくある質問と答え', 
  description = 'ご不明点は遠慮なくお問い合わせください',
  faqs = [
    {
      question: 'Q. 免責事項について',
      answer: 'A. ハマ塾は投資・金融リテラシーの向上を目的とした動画コンテンツを提供しています。本サービスは特定の金融商品の売買を推奨するものではなく、投資助言を行うものではありません。投資は自己責任の世界だからこそ、根拠に基づいた売買判断を自ら行える力を少しずつ鍛えていきましょう。',
    },
    {
      question: 'Q. 30日間の返金保証について',
      answer: 'A. 購入30日以内かつ進捗30%未満に限り全額返金対象です。（但し、返金時の振込手数料は購入者負担になります。）',
    },
    {
      question: 'Q. わからないところは質問できますか？',
      answer: 'A. ハマ塾では質問を大歓迎しています。「こんなこと聞いていいのかな？」という内容でも大丈夫なので、いつでも気軽にご質問ください。',
    },
    {
      question: 'Q. 上記以外の質問があるのですが？',
      answer: 'A. ページ最下部の「ご質問・お問い合わせはこちら」からお気軽にご質問ください。内容を確認の上、順次回答いたします。',
    },
  ]
} = Astro.props;
---

<section id="faq" class="relative bg-white/70 backdrop-blur-md py-8 md:py-20 overflow-hidden">
  <div class="lg:max-w-7xl mx-auto px-6">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-semibold text-black mb-2">{title}</h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto mt-3">{description}</p>
    </div>
    <div class="max-w-4xl lg:px-10 mx-auto space-y-4">
      {faqs.map((faq) => (
        <FaqItem question={faq.question} answer={faq.answer} />
      ))}
    </div>
  </div>
</section>