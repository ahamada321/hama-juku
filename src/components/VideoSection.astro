---
import VideoPagination from '@components/VideoPagination.astro';

interface Lecture {
  _id: string;
  title: string;
  preview: boolean;
  url: string;
  content: string;
}

interface Props {
  lecture: Lecture;
  prevPage: string;
  nextPage: string;
  nextPrev: boolean;
  slug: string;
  paid: boolean;
}

const { lecture, prevPage, nextPage, nextPrev, slug, paid } = Astro.props;
---

<section id="video" class="relative bg-white/70 backdrop-blur-md py-6 pb-8 overflow-hidden">
  <div class="max-w-4xl lg:px-10 mx-auto space-y-8">
    <div
      class="order-1 relative w-full rounded-xl border-[2px] aspect-video overflow-hidden flex flex-col items-center justify-center"
    >
      <!-- Video Content -->
      <iframe
        src={lecture.url}
        class="absolute top-0 inset-x-0 w-full h-full"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
    <!-- Additional Content -->
    { paid && (
    <div class="bg-white rounded-xl border border-black/10 shadow-lg mb-12">
      <div class="px-8 py-6 post-content" set:html={lecture.content} />
    </div>
    )}

    <VideoPagination prevPage={prevPage} nextPage={nextPage} nextPrev={nextPrev} slug={slug} paid={paid} />
  </div>
</section>